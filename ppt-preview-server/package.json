{
  "name": "ppt-preview-server",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Vite sandbox for PPT slide previews.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 18921 --strictPort",
    "typecheck": "vue-tsc --noEmit"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^3.0.3",
    "echarts": "^6.0.0",
    "gsap": "^3.15.0",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
